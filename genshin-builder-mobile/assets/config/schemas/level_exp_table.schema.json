{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LevelExpTable",
  "type": "object",
  "required": ["characterExp", "weaponExpByRarity"],
  "properties": {
    "version": { "type": "integer" },
    "description": { "type": "string" },
    "levelMarks": {
      "type": "array",
      "items": { "type": "integer" }
    },
    "characterExp": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "weaponExpByRarity": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "integer" }
      }
    }
  }
}
