{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DailyMaterialSchedule",
  "type": "object",
  "required": ["version", "talentSeries", "weaponSeries"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "talentSeries": { "$ref": "#/definitions/seriesList" },
    "weaponSeries": { "$ref": "#/definitions/seriesList" }
  },
  "definitions": {
    "seriesList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "days", "materialIds"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "region": { "type": "string" },
          "days": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "minimum": 1, "maximum": 7 }
          },
          "materialIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
